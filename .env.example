# Supabase (obtenha em: Settings > API do seu projeto)
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...sua-chave-aqui

# =====================================================
# SEM Supabase? O sistema funciona 100% offline
# com dados no localStorage do navegador.
# Basta NÃO preencher as variáveis acima.
# =====================================================
